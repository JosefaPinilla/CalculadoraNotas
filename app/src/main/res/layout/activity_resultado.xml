<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#D59AB3"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado Final"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#5A534B"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/txtPromedio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Promedio:"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:id="@+id/txtEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estado:"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <ImageView
        android:id="@+id/aprobado"
        android:layout_width="300dp"
        android:layout_height="220dp"
        android:src="@mipmap/aprobado_foreground"
        android:visibility="gone"
        android:layout_marginTop="10dp"/>

    <ImageView
        android:id="@+id/reprobado"
        android:layout_width="300dp"
        android:layout_height="220dp"
        android:src="@mipmap/reprobado_foreground"
        android:visibility="gone"
        android:layout_marginTop="10dp"/>

</LinearLayout>