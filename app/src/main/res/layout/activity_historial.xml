<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D59AB3"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de Estudiantes"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#5A534B"
        android:layout_marginBottom="10dp"/>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F2DA8A"
        android:padding="6dp"
        android:stretchColumns="0,1,2,3">

        <TableRow>

            <TextView
                android:text="Nombre"
                android:textStyle="bold"
                android:textColor="#5A534B"/>

            <TextView
                android:text="Asignatura"
                android:textStyle="bold"
                android:textColor="#5A534B"/>

            <TextView
                android:text="Estado"
                android:textStyle="bold"
                android:textColor="#5A534B"/>

            <TextView
                android:text="Nota"
                android:textStyle="bold"
                android:textColor="#5A534B"/>

        </TableRow>

    </TableLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver a calcular"
        android:layout_marginTop="10dp"
        android:backgroundTint="#F2DA8A"
        android:textColor="#5A534B"/>

    <Button
        android:id="@+id/btSalir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salir"
        android:backgroundTint="#E57373"
        android:textColor="#FFFFFF"/>

</LinearLayout>